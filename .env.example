# Telegram
BOT_TOKEN=123456:ABC-DEF...
# Список Telegram ID администраторов через запятую
ADMIN_IDS=111111111,222222222
# ID группы для дубля объявлений (опционально, оставь пустым чтобы отключить)
GROUP_ID=

# PostgreSQL
POSTGRES_USER=bordi
POSTGRES_PASSWORD=bordi
POSTGRES_DB=bordi
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (FSM storage)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Бизнес-параметры
# Окно поиска по дате (± дней)
SEARCH_DATE_WINDOW=2
# Лимит выдачи в поиске
SEARCH_LIMIT=20
# Часовой пояс для планировщика
TZ=Asia/Tashkent
# Время ночной деактивации (час, 0-23)
DEACTIVATE_HOUR=3
